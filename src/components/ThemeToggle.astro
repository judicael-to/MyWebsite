  <!-- Dark Mode Toggle -->
  <button
    id="theme-toggle"
    class="relative w-full h-10 bg-white/50 dark:bg-black/30 rounded-full p-1 flex items-center cursor-pointer"
  >
    <div
      class="absolute top-1 bottom-1 left-1 w-[calc(50%-4px)] bg-sky-300 dark:bg-sky-800 rounded-full shadow-sm transition-transform duration-300"
      id="toggle-circle"
    >
    </div>
    <span
      class="flex-1 text-xs font-bold relative z-10 text-center"
      data-i18n="light">Light</span
    >
    <span
      class="flex-1 text-xs font-bold relative z-10 text-center"
      data-i18n="dark">Dark</span
    >
  </button>

  <!-- Language Toggle -->
  <button
    id="lang-toggle"
    class="relative w-full h-10 bg-white/50 dark:bg-black/30 rounded-full p-1 flex items-center cursor-pointer mt-2"
  >
    <div
      class="absolute top-1 bottom-1 left-1 w-[calc(50%-4px)] bg-sky-300 dark:bg-sky-800 rounded-full shadow-sm transition-transform duration-300"
      id="lang-circle"
    >
    </div>
    <span class="flex-1 text-xs font-bold relative z-10 text-center">FR</span>
