  // 2. Function to update text on the page
  function applyTranslations(lang: string) {
    const langKey = lang as keyof typeof translations;
    const elements = document.querySelectorAll("[data-i18n]");
    elements.forEach((element) => {
      const key = element.getAttribute(
        "data-i18n",
      ) as keyof (typeof translations)[typeof langKey];
      if (translations[langKey] && translations[langKey][key]) {
        (element as HTMLElement).innerText = translations[langKey][key];
      }
    });

    const placeholders = document.querySelectorAll("[data-i18n-placeholder]");
    placeholders.forEach((element) => {
      const key = element.getAttribute(
        "data-i18n-placeholder",
      ) as keyof (typeof translations)[typeof langKey];
      if (translations[langKey] && translations[langKey][key]) {
        (element as HTMLInputElement).placeholder = translations[langKey][key];
      }
    });
  }

  // Theme Toggle Logic
  const themeToggleBtn = document.getElementById("theme-toggle");
  const toggleCircle = document.getElementById("toggle-circle");
  const htmlElement = document.documentElement;

  // Initialize Theme State
  if (htmlElement.classList.contains("dark")) {
    toggleCircle?.classList.add("translate-x-full");
  }

  themeToggleBtn?.addEventListener("click", () => {
    htmlElement.classList.toggle("dark");
    if (htmlElement.classList.contains("dark")) {
      localStorage.setItem("theme", "dark");
      toggleCircle?.classList.add("translate-x-full");
    } else {
      localStorage.setItem("theme", "light");
      toggleCircle?.classList.remove("translate-x-full");
    }
  });

  // Language Toggle Logic
  const langToggleBtn = document.getElementById("lang-toggle");
  const langCircle = document.getElementById("lang-circle");

  // Initialize Language State (Default EN)
  let currentLang = localStorage.getItem("lang") || "en";
  if (currentLang === "fr") {
    langCircle?.classList.add("translate-x-full");
  }

  // Apply initial translations
  applyTranslations(currentLang);

  langToggleBtn?.addEventListener("click", () => {
    if (currentLang === "en") {
      currentLang = "fr";
      langCircle?.classList.add("translate-x-full");
    } else {
      currentLang = "en";
      langCircle?.classList.remove("translate-x-full");
    }
    localStorage.setItem("lang", currentLang);
    applyTranslations(currentLang);
  });
</script>
