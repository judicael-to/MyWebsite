<div
  class="glass-card col-span-1 md:col-span-1 md:row-span-1 bg-sky-100 dark:bg-sky-900/40 rounded-3xl p-6 opacity-0 animate-drop-bounce delay-200 flex flex-col justify-center items-center text-center relative overflow-hidden"
>
  <div class="absolute top-4 right-4">
    <i
      class="fas fa-cog text-sky-900/20 dark:text-sky-100/20 text-6xl rotate-45"
    ></i>
  </div>
  <p
    class="text-sm font-semibold uppercase tracking-wider text-sky-900 dark:text-sky-100 mb-4"
    data-i18n="settings"
  >
    Settings
  </p>

  <!-- Dark Mode Toggle -->
  <button
    id="theme-toggle"
    class="relative w-full h-10 bg-white/50 dark:bg-black/30 rounded-full p-1 flex items-center cursor-pointer"
  >
    <div
      class="absolute top-1 bottom-1 left-1 w-[calc(50%-4px)] bg-sky-300 dark:bg-sky-800 rounded-full shadow-sm transition-transform duration-300"
      id="toggle-circle"
    >
    </div>
    <span
      class="flex-1 text-xs font-bold relative z-10 text-center"
      data-i18n="light">Light</span
    >
    <span
      class="flex-1 text-xs font-bold relative z-10 text-center"
      data-i18n="dark">Dark</span
    >
  </button>

  <!-- Language Toggle -->
  <button
    id="lang-toggle"
    class="relative w-full h-10 bg-white/50 dark:bg-black/30 rounded-full p-1 flex items-center cursor-pointer mt-2"
  >
    <div
      class="absolute top-1 bottom-1 left-1 w-[calc(50%-4px)] bg-sky-300 dark:bg-sky-800 rounded-full shadow-sm transition-transform duration-300"
      id="lang-circle"
    >
    </div>
    <span class="flex-1 text-xs font-bold relative z-10 text-center">EN</span>
    <span class="flex-1 text-xs font-bold relative z-10 text-center">FR</span>
  </button>
</div>

