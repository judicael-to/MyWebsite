---
import Layout from "../layouts/Layout.astro";
import ProfileCard from "../components/ProfileCard.astro";
import ThemeToggle from "../components/ThemeToggle.astro";
import SkillsCard from "../components/SkillsCard.astro";
import StatusCard from "../components/StatusCard.astro";
import ContactCard from "../components/ContactCard.astro";
import ProjectsCard from "../components/ProjectsCard.astro";
import InternshipCard from "../components/InternshipCard.astro";
import Timeline from "../components/Timeline.astro";
---

<Layout title="Judicael - Portfolio">
  <!-- Main Wrapper -->
  <div class="max-w-6xl mx-auto px-4 py-8 md:py-16">
    <!-- GRID HERO SECTION -->
    <div
      class="grid grid-cols-1 md:grid-cols-4 md:grid-rows-3 gap-5 h-auto md:h-[800px] mb-24"
    >
      <ProfileCard />
      <InternshipCard />
      <ThemeToggle />
      <StatusCard />
      <SkillsCard />
      <ContactCard />
      <ProjectsCard />
    </div>

    <!-- DETAILED SCROLL SECTIONS -->

    <!-- Timeline / Sandbox Section -->
    <Timeline />

    <!-- Projects Section -->
    <section
      id="projects-detail"
      class="py-20 opacity-0 transition-opacity duration-1000 translate-y-10 scroll-reveal"
    >
      <div class="flex items-end gap-4 mb-12">
        <h2
          class="text-6xl md:text-8xl font-serif font-bold text-slate-200 dark:text-slate-800 select-none absolute -z-10"
          data-i18n="works"
        >
          WORKS
        </h2>
        <h2
          class="text-3xl md:text-4xl font-bold pl-2"
          data-i18n="featured_projects"
        >
          Featured Projects
        </h2>
        <div class="h-px bg-slate-300 grow mb-4 ml-4"></div>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
        <!-- Project 1: Sophrology Website -->
        <div
          class="group bg-white dark:bg-slate-800 rounded-3xl overflow-hidden shadow-xl hover:shadow-2xl transition-all duration-300 border border-slate-100 dark:border-slate-700"
        >
          <div
            class="h-64 bg-slate-100 dark:bg-slate-700 relative overflow-hidden group-hover:scale-105 transition-transform duration-500"
          >
            <img
              src="/sophro.png"
              alt="Sophrology Website Demo"
              class="w-full h-full object-cover"
            />
          </div>
          <div class="p-8">
            <div class="flex justify-between items-start mb-4">
              <div>
                <h3 class="text-2xl font-bold mb-1" data-i18n="proj1_title">
                  Sophrology Website
                </h3>
                <p
                  class="text-sm text-slate-500 dark:text-slate-400"
                  data-i18n="proj1_tags"
                >
                  Astro • Tailwind CSS • React
                </p>
              </div>
              <a
                href="#"
                class="w-10 h-10 rounded-full bg-slate-100 dark:bg-slate-700 flex items-center justify-center hover:bg-slate-900 hover:text-white transition-colors"
              >
                <i class="fas fa-arrow-right"></i>
              </a>
            </div>
            <p
              class="text-slate-600 dark:text-slate-300"
              data-i18n="proj1_desc"
            >
              A modern and serene website featuring responsive design, SEO
              optimization, and interactive appointment modules.
            </p>
          </div>
        </div>

        <!-- Project 2: Group Management App -->
        <div
          class="group bg-white dark:bg-slate-800 rounded-3xl overflow-hidden shadow-xl hover:shadow-2xl transition-all duration-300 border border-slate-100 dark:border-slate-700"
        >
          <div
            class="h-64 bg-slate-100 dark:bg-slate-700 relative overflow-hidden group-hover:scale-105 transition-transform duration-500"
          >
            <img
              src="/tptd.png"
              alt="Group Management App Demo"
              class="w-full h-full object-cover"
            />
          </div>
          <div class="p-8">
            <div class="flex justify-between items-start mb-4">
              <div>
                <h3 class="text-2xl font-bold mb-1" data-i18n="proj2_title">
                  Group Management App
                </h3>
                <p
                  class="text-sm text-slate-500 dark:text-slate-400"
                  data-i18n="proj2_tags"
                >
                  MySQL • Java • PHP • API REST
                </p>
              </div>
              <a
                href="#"
                class="w-10 h-10 rounded-full bg-slate-100 dark:bg-slate-700 flex items-center justify-center hover:bg-slate-900 hover:text-white transition-colors"
              >
                <i class="fas fa-arrow-right"></i>
              </a>
            </div>
            <p
              class="text-slate-600 dark:text-slate-300"
              data-i18n="proj2_desc"
            >
              Database design and load balancing algorithms with interactive
              dashboards for data visualization.
            </p>
          </div>
        </div>

        <!-- Project 3: Cité universitaire App -->
        <div
          class="group bg-white dark:bg-slate-800 rounded-3xl overflow-hidden shadow-xl hover:shadow-2xl transition-all duration-300 border border-slate-100 dark:border-slate-700"
        >
          <div
            class="h-64 bg-slate-100 dark:bg-slate-700 relative overflow-hidden group-hover:scale-105 transition-transform duration-500"
          >
            <!-- Placeholder icon for image -->
            <img
              src="/citeU.png"
              alt="cité universitaire"
              class="w-full h-full object-cover"
            />
          </div>
          <div class="p-8">
            <div class="flex justify-between items-start mb-4">
              <div>
                <h3 class="text-2xl font-bold mb-1" data-i18n="proj3_title">
                  Dormitory Management App
                </h3>
                <p
                  class="text-sm text-slate-500 dark:text-slate-400"
                  data-i18n="proj3_tags"
                >
                  Java • Penpot
                </p>
              </div>
              <a
                href="#"
                class="w-10 h-10 rounded-full bg-slate-100 dark:bg-slate-700 flex items-center justify-center hover:bg-slate-900 hover:text-white transition-colors"
              >
                <i class="fas fa-arrow-right"></i>
              </a>
            </div>
            <p
              class="text-slate-600 dark:text-slate-300"
              data-i18n="proj3_desc"
            >
              Object-oriented management application focusing on robust software
              architecture and intuitive UI.
            </p>
          </div>
        </div>

        <!-- Project 4: Network Infrastructure -->
        <div
          class="group bg-white dark:bg-slate-800 rounded-3xl overflow-hidden shadow-xl hover:shadow-2xl transition-all duration-300 border border-slate-100 dark:border-slate-700"
        >
          <div
            class="h-64 bg-linear-to-br from-green-100 to-emerald-100 dark:from-slate-700 dark:to-slate-600 p-8 flex items-center justify-center group-hover:scale-105 transition-transform duration-500"
          >
            <!-- Placeholder icon for image -->
            <i
              class="fas fa-network-wired text-6xl text-slate-300 dark:text-slate-500"
            ></i>
          </div>
          <div class="p-8">
            <div class="flex justify-between items-start mb-4">
              <div>
                <h3 class="text-2xl font-bold mb-1" data-i18n="proj4_title">
                  Network Infrastructure
                </h3>
                <p
                  class="text-sm text-slate-500 dark:text-slate-400"
                  data-i18n="proj4_tags"
                >
                  SSH • Routing
                </p>
              </div>
              <a
                href="#"
                class="w-10 h-10 rounded-full bg-slate-100 dark:bg-slate-700 flex items-center justify-center hover:bg-slate-900 hover:text-white transition-colors"
              >
                <i class="fas fa-arrow-right"></i>
              </a>
            </div>
            <p
              class="text-slate-600 dark:text-slate-300"
              data-i18n="proj4_desc"
            >
              Multi-team network setup applying system administration concepts,
              routing tables, and secure remote access.
            </p>
          </div>
        </div>

        <!-- Project 5: 2D Video Game -->
        <div
          class="group bg-white dark:bg-slate-800 rounded-3xl overflow-hidden shadow-xl hover:shadow-2xl transition-all duration-300 border border-slate-100 dark:border-slate-700"
        >
          <div
            class="h-64 bg-slate-100 dark:bg-slate-700 relative overflow-hidden group-hover:scale-105 transition-transform duration-500"
          >
            <!-- Placeholder icon for image -->
            <img src="/2d.png" alt="Game" class="w-full h-full object-cover" />
          </div>
          <div class="p-8">
            <div class="flex justify-between items-start mb-4">
              <div>
                <h3 class="text-2xl font-bold mb-1" data-i18n="proj5_title">
                  2D Video Game
                </h3>
                <p
                  class="text-sm text-slate-500 dark:text-slate-400"
                  data-i18n="proj5_tags"
                >
                  C++ • SDL2
                </p>
              </div>
              <a
                href="#"
                class="w-10 h-10 rounded-full bg-slate-100 dark:bg-slate-700 flex items-center justify-center hover:bg-slate-900 hover:text-white transition-colors"
              >
                <i class="fas fa-arrow-right"></i>
              </a>
            </div>
            <p
              class="text-slate-600 dark:text-slate-300"
              data-i18n="proj5_desc"
            >
              Developed a video game using a custom engine managing levels,
              characters, and interactions.
            </p>
          </div>
        </div>

        <!-- Project 6: Database Design -->
        <div
          class="group bg-white dark:bg-slate-800 rounded-3xl overflow-hidden shadow-xl hover:shadow-2xl transition-all duration-300 border border-slate-100 dark:border-slate-700"
        >
          <div
            class="h-64 bg-linear-to-br from-amber-100 to-yellow-100 dark:from-slate-700 dark:to-slate-600 p-8 flex items-center justify-center group-hover:scale-105 transition-transform duration-500"
          >
            <!-- Placeholder icon for image -->
            <i
              class="fas fa-database text-6xl text-slate-300 dark:text-slate-500"
            ></i>
          </div>
          <div class="p-8">
            <div class="flex justify-between items-start mb-4">
              <div>
                <h3 class="text-2xl font-bold mb-1" data-i18n="proj6_title">
                  Database Design
                </h3>
                <p
                  class="text-sm text-slate-500 dark:text-slate-400"
                  data-i18n="proj6_tags"
                >
                  SQL • UML
                </p>
              </div>
              <a
                href="#"
                class="w-10 h-10 rounded-full bg-slate-100 dark:bg-slate-700 flex items-center justify-center hover:bg-slate-900 hover:text-white transition-colors"
              >
                <i class="fas fa-arrow-right"></i>
              </a>
            </div>
            <p
              class="text-slate-600 dark:text-slate-300"
              data-i18n="proj6_desc"
            >
              UML modeling and complex SQL scripts (Triggers, Stored Procedures)
              optimizing large data volumes.
            </p>
          </div>
        </div>
      </div>
    </section>

    <!-- About / Skills Detail Section -->
    <section
      id="skills-detail"
      class="py-20 opacity-0 transition-opacity duration-1000 translate-y-10 scroll-reveal"
    >
      <div
        class="bg-slate-900 text-white rounded-3xl p-8 md:p-16 relative overflow-hidden"
      >
        <div
          class="absolute top-0 right-0 w-64 h-64 bg-purple-500 rounded-full blur-3xl opacity-20 -translate-y-1/2 translate-x-1/3"
        >
        </div>
        <div
          class="absolute bottom-0 left-0 w-64 h-64 bg-blue-500 rounded-full blur-3xl opacity-20 translate-y-1/2 -translate-x-1/3"
        >
        </div>

        <div class="relative z-10 grid grid-cols-1 md:grid-cols-2 gap-12">
          <div class="flex flex-col justify-center">
            <h2
              class="text-3xl md:text-5xl font-serif font-bold mb-6"
              data-i18n="toolbox_title"
            >
              My Digital Toolbox
            </h2>
            <p
              class="text-slate-300 text-lg leading-relaxed mb-8"
              data-i18n="toolbox_desc"
            >
              I believe in choosing the right tool for the job. While I
              specialize in Python and C for backend logic, I love crafting
              beautiful interfaces with modern web technologies.
            </p>
            <a
              href="/CV.pdf"
              download
              class="inline-block bg-white text-black px-6 py-3 rounded-full font-bold hover:bg-slate-200 transition-colors w-fit"
              data-i18n="download_cv"
            >
              Download CV
            </a>
          </div>
          <div class="grid grid-cols-2 gap-4">
            <div class="bg-white/10 p-6 rounded-2xl backdrop-blur-sm">
              <i class="fab fa-python text-4xl text-yellow-300 mb-4"></i>
              <h4 class="font-bold text-xl">Python</h4>
              <p class="text-sm text-slate-400" data-i18n="skill_python_desc">
                Advanced Data Analysis
              </p>
            </div>
            <div class="bg-white/10 p-6 rounded-2xl backdrop-blur-sm">
              <i class="fas fa-code text-4xl text-blue-300 mb-4"></i>
              <h4 class="font-bold text-xl">C / C++</h4>
              <p class="text-sm text-slate-400" data-i18n="skill_c_desc">
                System Programming
              </p>
            </div>
            <div class="bg-white/10 p-6 rounded-2xl backdrop-blur-sm">
              <i class="fab fa-figma text-4xl text-pink-300 mb-4"></i>
              <h4 class="font-bold text-xl" data-i18n="skill_design_title">
                Design
              </h4>
              <p class="text-sm text-slate-400" data-i18n="skill_design_desc">
                UI/UX Prototyping
              </p>
            </div>
            <div class="bg-white/10 p-6 rounded-2xl backdrop-blur-sm">
              <i class="fas fa-server text-4xl text-green-300 mb-4"></i>
              <h4 class="font-bold text-xl" data-i18n="skill_backend_title">
                Backend
              </h4>
              <p class="text-sm text-slate-400" data-i18n="skill_backend_desc">
                SQL & APIs
              </p>
            </div>
            <div class="bg-white/10 p-6 rounded-2xl backdrop-blur-sm">
              <i class="fas fa-users text-4xl text-orange-300 mb-4"></i>
              <h4 class="font-bold text-xl" data-i18n="skill_soft_title">
                Soft Skills
              </h4>
              <p class="text-sm text-slate-400" data-i18n="skill_soft_desc">
                Analysis & Rigor
              </p>
            </div>
            <div class="bg-white/10 p-6 rounded-2xl backdrop-blur-sm">
              <i class="fas fa-language text-4xl text-sky-300 mb-4"></i>
              <h4 class="font-bold text-xl" data-i18n="skill_lang_title">
                Languages
              </h4>
              <p class="text-sm text-slate-400" data-i18n="skill_lang_desc">
                French & English
              </p>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Contact Section -->
    <section
      id="contact-detail"
      class="py-20 opacity-0 transition-opacity duration-1000 translate-y-10 scroll-reveal"
    >
      <div
        class="bg-peach-100 dark:bg-slate-800 rounded-3xl p-8 md:p-12 border border-orange-200 dark:border-slate-700"
      >
        <div class="text-center max-w-2xl mx-auto mb-10">
          <h2
            class="text-3xl md:text-4xl font-bold mb-4"
            data-i18n="contact_title"
          >
            Ready to start a project?
          </h2>
          <p
            class="text-slate-600 dark:text-slate-300"
            data-i18n="contact_desc"
          >
            Whether you have a question or just want to say hi, I'll try my best
            to get back to you!
          </p>
        </div>

        <form class="max-w-lg mx-auto space-y-4">
          <div class="grid grid-cols-2 gap-4">
            <input
              type="text"
              placeholder="Name"
              data-i18n-placeholder="name_placeholder"
              class="w-full p-4 rounded-xl bg-white dark:bg-slate-900 border-none focus:ring-2 focus:ring-orange-400 outline-none transition-all"
            />
            <input
              type="email"
              placeholder="Email"
              data-i18n-placeholder="email_placeholder"
              class="w-full p-4 rounded-xl bg-white dark:bg-slate-900 border-none focus:ring-2 focus:ring-orange-400 outline-none transition-all"
            />
          </div>
          <input
            type="text"
            placeholder="Subject"
            data-i18n-placeholder="subject_placeholder"
            class="w-full p-4 rounded-xl bg-white dark:bg-slate-900 border-none focus:ring-2 focus:ring-orange-400 outline-none transition-all"
          />
          <textarea
            rows="4"
            placeholder="Message"
            data-i18n-placeholder="message_placeholder"
            class="w-full p-4 rounded-xl bg-white dark:bg-slate-900 border-none focus:ring-2 focus:ring-orange-400 outline-none transition-all"
          ></textarea>
          <button
            type="button"
            class="w-full bg-slate-900 dark:bg-orange-500 text-white font-bold py-4 rounded-xl hover:opacity-90 transition-opacity"
            data-i18n="send_message"
          >
            Send Message
          </button>
        </form>
      </div>
    </section>

    <!-- Footer -->
    <footer class="text-center text-slate-400 text-sm py-8 mt-8">
      <p>
        © 2024 • <span data-i18n="footer_crafted">Crafted with</span>
        <span class="text-red-500">❤</span>
        <span data-i18n="footer_by">by</span> Judicael
      </p>
    </footer>
  </div>
</Layout>

<script is:inline>
  // Smooth Scroll Helper
  window.scrollToSection = function (id) {
    const element = document.getElementById(id);
    if (element) {
      element.scrollIntoView({ behavior: "smooth" });
    }
  };

  // Scroll Observer for Fade-in Animations
  const observerOptions = {
    root: null,
    rootMargin: "0px",
    threshold: 0.1,
  };

  const observer = new IntersectionObserver((entries, observer) => {
    entries.forEach((entry) => {
      if (entry.isIntersecting) {
        entry.target.classList.remove("opacity-0", "translate-y-10");
        observer.unobserve(entry.target);
      }
    });
  }, observerOptions);

  document.querySelectorAll(".scroll-reveal").forEach((section) => {
    observer.observe(section);
  });
</script>
